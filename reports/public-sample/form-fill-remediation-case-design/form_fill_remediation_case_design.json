  "policy_guidance": [
    {
      "guidance": "If the user specifies a concrete form field and asks the assistant to fill or confirm it, route to `form_fill` even when the value itself is absent; use `clarify` only when the target field/action is ambiguous.",
      "guidance_id": "form-fill-clarify-boundary-policy",
      "review_rationale": "A small but high-impact bucket turns concrete field-fill requests into `clarify`, changing task type, route, safety reason, and slot shape.",
      "source_bucket": "clarify_boundary_confusion"
    },
    {
      "guidance": "When the user explicitly asks to confirm after filling a form field, preserve that confirmation intent in `normalized_command`, set `confirmation_required=true`, and keep `safety.reason=requires_confirmation`.",
      "guidance_id": "form-fill-confirmation-marker-policy",
      "review_rationale": "The largest residual bucket drops or reorders the explicit `并确认` marker even when the contract otherwise stays in the form-fill family.",
      "source_bucket": "confirmation_marker_missing_or_reordered"
    },
    {
      "guidance": "For `form_fill` slots, preserve the most specific field name from the request; do not collapse domain-specific fields such as 收货地址, 发票抬头, or 预约时间 into generic aliases.",
      "guidance_id": "form-fill-field-specificity-policy",
      "review_rationale": "The second-largest bucket keeps the slot shape but loses specificity, for example 收货地址 to 地址 or 发票抬头 to 抬头.",
      "source_bucket": "field_name_specificity_drift"
    }
  ],
