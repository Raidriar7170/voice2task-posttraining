{
  "base_model": "Qwen/Qwen2.5-0.5B-Instruct",
  "allow_heavy_training": false,
  "beta": 0.1,
  "dataset_split": "train",
  "dev_split": "dev",
  "lora": {
    "alpha": 16,
    "dropout": 0.05,
    "r": 8,
    "target_modules": ["q_proj", "v_proj"]
  },
  "max_prompt_length": 768,
  "max_seq_length": 1024,
  "num_train_epochs": 1,
  "output_policy": "dry_run_by_default_run_training_requires_explicit_opt_in",
  "per_device_train_batch_size": 1,
  "reference_runtime": "local-dev",
  "sft_model_ref": "reports/public-sample/sft-dry-run/adapter",
  "dpo_initialization": "base_model_lora_with_sft_ref_metadata",
  "trainer": "trl.DPOTrainer"
}
